{
  "name": "ai-counseling-extension",
  "version": "0.1.0",
  "description": "A minimal Chrome extension foundation built with WXT, React, and TypeScript.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wxt -b chrome --host 127.0.0.1 --port 3000",
    "dev:brave": "WXT_CHROMIUM_BINARY=./scripts/brave-flatpak wxt -b chrome --host 127.0.0.1 --port 3000",
    "dev:chrome-flatpak": "WXT_CHROMIUM_BINARY=./scripts/chrome-flatpak wxt -b chrome --host 127.0.0.1 --port 3000",
    "dev:manual": "WXT_MANUAL_DEV=true wxt -b chrome --host 127.0.0.1 --port 3001",
    "build": "wxt build -b chrome",
    "compile": "wxt prepare && tsc --noEmit",
    "zip": "wxt zip -b chrome"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@tailwindcss/vite": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "typescript": "^6.0.3",
    "wxt": "^0.20.27"
  }
}
